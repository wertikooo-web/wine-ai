{
  "name": "wine-ai-realtime",
  "version": "0.1.0",
  "private": true,
  "description": "Independent realtime voice lab for a Moldovan wine digital expert, built on a reusable realtime core.",
  "main": "src/server.js",
  "scripts": {
    "prestart": "node scripts/knowledge-republish.js && node scripts/knowledge-index.js",
    "knowledge:republish": "node scripts/knowledge-republish.js",
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "knowledge:index": "node scripts/knowledge-index.js",
    "knowledge:check": "node scripts/knowledge-check.js",
    "knowledge:update": "node scripts/knowledge-update.js",
    "test": "node scripts/run-tests.js",
    "test:smoke": "node scripts/run-smoke.js",
    "smoke:http": "node scripts/http-smoke.js",
    "smoke:realtime": "node scripts/realtime-smoke.js",
    "smoke:language": "node scripts/language-smoke.js",
    "smoke:knowledge": "node scripts/knowledge-smoke.js",
    "lint": "node --check src/server.js",
    "typecheck": "echo \"no build-time typecheck configured (JS + JSDoc project); see AGENTS.md\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@xmldom/xmldom": "^0.9.10",
    "adm-zip": "^0.6.0",
    "cheerio": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0"
  }
}
