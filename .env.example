PORT=3200
REALTIME_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Kore
VOICE_ID=Kore

# Grok Voice / xAI. GROK_API_KEY is preferred; XAI_API_KEY is also supported.
GROK_API_KEY=
GROK_VOICE_MODEL=grok-voice-latest
GROK_VOICE_ID=rex
GROK_REALTIME_URL=wss://api.x.ai/v1/realtime

# Push-to-talk silence tail (see docs/ARCHITECTURE.md) — matches the proven
# lunara-realtime value; only change with a measured reason.
PTT_SILENCE_TAIL_MS=300
PTT_TURN_TIMEOUT_MS=4500

# Mock provider (no API key needed) — used when REALTIME_PROVIDER=mock.
MOCK_PROCESSING_DELAY_MS=650
MOCK_CHUNK_INTERVAL_MS=220
MOCK_CHUNK_DURATION_MS=260
MOCK_CHUNK_COUNT=8
MOCK_SAMPLE_RATE=16000
MOCK_TONE_HZ=440

# Avatar
AVATAR_PROVIDER=mock
AVATAR_API_KEY=

# Knowledge base
KNOWLEDGE_STORE=local
KNOWLEDGE_PATH=./knowledge

# Discovered-documents queue (src/knowledge/discovered/store.js): falls
# back to knowledge/discovered/*.json when unset. On Railway this is set
# automatically as a reference to the attached Postgres addon
# (${{Postgres.DATABASE_URL}}) - never paste a real connection string here.
DATABASE_URL=

DEFAULT_LANGUAGE=auto
LOG_LEVEL=info

# Off by default. Turning this on stores raw session audio to disk for
# debugging — never enable without explicit user consent.
SAVE_AUDIO=false

# WINE AI KOS object storage. Keep 'local' for local development; switching a
# deployed environment is a separate, explicit operation.
KOS_STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_FORCE_PATH_STYLE=false
S3_OBJECT_PREFIX=
S3_SIGNED_URL_TTL_SECONDS=3600
# Browser-rendered local 3D avatar. Disabled by default when NODE_ENV=production.
AVATAR_3D_ENABLED=false
# Keep the standalone avatar lab local unless explicitly enabled in production.
AVATAR_DEV_PANEL=false
